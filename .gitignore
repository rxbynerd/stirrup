.env
# Anchor these patterns to the repo root so they match the built binaries
# only, not the `harness/cmd/stirrup/` source directory (which otherwise
# has all of its files silently ignored by git).
/stirrup
/stirrup-eval
tmp/*

# Transient eval run output (per-task traces, harness stdout/stderr, JUnit).
# CI writes this tree and uploads it as an artifact; baselines under
# eval/baselines/ are the committed reference, not these run results.
/eval/results/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# ???
.beads/interactions.jsonl
.beads/issues.jsonl
