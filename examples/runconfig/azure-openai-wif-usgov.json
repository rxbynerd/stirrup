{
  "runId": "azure-openai-wif-usgov-example",
  "mode": "execution",
  "prompt": "Replace this prompt with the task you want the harness to run.",
  "provider": {
    "type": "openai-compatible",
    "baseUrl": "https://your-resource.openai.azure.us/openai/v1",
    "queryParams": {
      "api-version": "preview"
    },
    "credential": {
      "type": "azure-workload-identity",
      "azureTenantId": "00000000-0000-0000-0000-000000000000",
      "azureClientId": "11111111-1111-1111-1111-111111111111",
      "azureTokenUrl": "https://login.microsoftonline.us/00000000-0000-0000-0000-000000000000/oauth2/v2.0/token",
      "tokenSource": {
        "type": "file",
        "path": "/var/run/secrets/azure/tokens/azure-identity-token"
      }
    }
  },
  "modelRouter": {
    "type": "static",
    "provider": "openai-compatible",
    "model": "gpt-4o"
  },
  "promptBuilder": {
    "type": "default"
  },
  "contextStrategy": {
    "type": "sliding-window",
    "maxTokens": 200000
  },
  "executor": {
    "type": "local",
    "workspace": "/tmp/stirrup-workspace"
  },
  "editStrategy": {
    "type": "multi"
  },
  "verifier": {
    "type": "none"
  },
  "permissionPolicy": {
    "type": "allow-all"
  },
  "gitStrategy": {
    "type": "none"
  },
  "transport": {
    "type": "stdio"
  },
  "traceEmitter": {
    "type": "jsonl",
    "filePath": "/tmp/stirrup.trace.jsonl"
  },
  "tools": {
    "builtIn": [
      "read_file",
      "list_directory",
      "grep_files",
      "find_files",
      "edit_file",
      "run_command"
    ]
  },
  "maxTurns": 20,
  "timeout": 600,
  "logLevel": "info"
}
