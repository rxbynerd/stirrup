{
  "runId": "openai-wif-gha-example",
  "mode": "execution",
  "prompt": "Replace this prompt with the task you want the harness to run.",
  "provider": {
    "type": "openai-responses",
    "baseUrl": "https://api.openai.com/v1",
    "credential": {
      "type": "openai-wif",
      "openaiIdentityProviderId": "idp_example",
      "openaiServiceAccountId": "sa_example",
      "tokenSource": {
        "type": "github-actions-oidc",
        "audience": "https://api.openai.com/v1"
      }
    }
  },
  "modelRouter": {
    "type": "static",
    "provider": "openai-responses",
    "model": "gpt-5.4-nano"
  },
  "promptBuilder": {
    "type": "default"
  },
  "contextStrategy": {
    "type": "sliding-window",
    "maxTokens": 200000
  },
  "executor": {
    "type": "local",
    "workspace": "/tmp/stirrup-workspace"
  },
  "editStrategy": {
    "type": "multi"
  },
  "verifier": {
    "type": "none"
  },
  "permissionPolicy": {
    "type": "allow-all"
  },
  "gitStrategy": {
    "type": "none"
  },
  "transport": {
    "type": "stdio"
  },
  "traceEmitter": {
    "type": "jsonl",
    "filePath": "/tmp/stirrup.trace.jsonl"
  },
  "tools": {
    "builtIn": [
      "read_file",
      "list_directory",
      "grep_files",
      "find_files",
      "edit_file",
      "run_command"
    ]
  },
  "maxTurns": 20,
  "timeout": 600,
  "logLevel": "info"
}
