{
  "runId": "azure-openai-wif-smoke",
  "mode": "execution",
  "prompt": "Replace this prompt with the task you want the harness to run.",
  "provider": {
    "type": "openai-responses",
    "baseUrl": "https://stirrup-eval-resource.cognitiveservices.azure.com/openai/v1",
    "queryParams": {
      "api-version": "preview"
    },
    "credential": {
      "type": "azure-workload-identity",
      "azureTenantId": "070edf67-6378-4bb0-9f3a-dce13cf67a36",
      "azureClientId": "3d4df370-c289-49f2-aa79-c9d83237ebd8",
      "tokenSource": {
        "type": "github-actions-oidc",
        "audience": "api://AzureADTokenExchange"
      }
    }
  },
  "modelRouter": {
    "type": "static",
    "provider": "openai-responses",
    "model": "gpt-5.4-nano"
  },
  "promptBuilder": {
    "type": "default"
  },
  "contextStrategy": {
    "type": "sliding-window",
    "maxTokens": 200000
  },
  "executor": {
    "type": "local",
    "workspace": "/tmp/stirrup-workspace"
  },
  "editStrategy": {
    "type": "multi"
  },
  "verifier": {
    "type": "none"
  },
  "permissionPolicy": {
    "type": "allow-all"
  },
  "gitStrategy": {
    "type": "none"
  },
  "transport": {
    "type": "stdio"
  },
  "traceEmitter": {
    "type": "jsonl",
    "filePath": "/tmp/stirrup.trace.jsonl"
  },
  "tools": {
    "builtIn": [
      "read_file",
      "list_directory",
      "search_files",
      "edit_file",
      "run_command"
    ]
  },
  "maxTurns": 20,
  "timeout": 600,
  "logLevel": "info"
}
