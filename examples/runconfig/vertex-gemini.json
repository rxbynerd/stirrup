{
  "runId": "vertex-gemini-example",
  "mode": "execution",
  "prompt": "Replace this prompt with the task you want the harness to run.",
  "provider": {
    "type": "gemini",
    "gcpProject": "my-project-id",
    "gcpLocation": "global"
  },
  "modelRouter": {
    "type": "static",
    "provider": "gemini",
    "model": "gemini-2.5-pro"
  },
  "promptBuilder": {
    "type": "default"
  },
  "contextStrategy": {
    "type": "sliding-window",
    "maxTokens": 200000
  },
  "executor": {
    "type": "local",
    "workspace": "/tmp/stirrup-workspace"
  },
  "editStrategy": {
    "type": "multi"
  },
  "verifier": {
    "type": "none"
  },
  "permissionPolicy": {
    "type": "deny-side-effects"
  },
  "gitStrategy": {
    "type": "none"
  },
  "transport": {
    "type": "stdio"
  },
  "traceEmitter": {
    "type": "jsonl",
    "filePath": "/tmp/stirrup.trace.jsonl"
  },
  "tools": {
    "builtIn": [
      "read_file",
      "list_directory",
      "search_files",
      "edit_file",
      "run_command"
    ]
  },
  "maxTurns": 20,
  "timeout": 600,
  "logLevel": "info"
}
